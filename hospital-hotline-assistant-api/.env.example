DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_hotline
APP_NAME=Hospital Hotline Assistant API
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
MOCK_NOTIFIER_ENABLED=true
NOTIFICATION_WEBHOOK_URL=
ALERT_SEVERITY_THRESHOLD=emergency
ALERT_COOLDOWN_SECONDS=300
GOOGLE_AI_ENABLED=true
# Switch google-genai (and ADK underneath it) to Vertex AI mode. When true,
# auth comes from GOOGLE_APPLICATION_CREDENTIALS + project/location below;
# no API key is needed. Set to false to use the Gemini API with GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
# General Gemini model for non-triage features (e.g. surveillance extraction).
GOOGLE_MODEL_NAME=gemini-3.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Screening engine (LangGraph — the only triage/voice engine) ─────────────
# Screening LLM adapter: vertexai (Gemini, default) now; openai_compatible
# (vLLM/Ollama) later. gemini-2.5-flash is the low-latency extraction model.
SCREENING_MODEL_PROVIDER=vertexai
SCREENING_MODEL_NAME=gemini-3.1-flash-lite

# ── Hospital HIS integration ────────────────────────────────────────────────

# Hospital HIS. mock = logs referrals, accepts every visit (no external DB).
# http = talk to the hospital HIS API, or the local hospital-his-mock service.
HIS_MODE=http
HIS_BASE_URL=http://localhost:8001
HIS_API_KEY=demo-his-key

# Omron blood pressure cuff (omblepy) integration.
# BP_DEVICE_MAC: macOS CoreBluetooth UUID (or MAC on win/linux) of the cuff,
# found via `python omblepy.py -p -d <model>` device scan. Pair once with -p.
BP_DEVICE_NAME=hem-7280t
BP_DEVICE_MAC=
# Optional overrides: BP_OMBLEPY_DIR (defaults to <repo>/omblepy),
# BP_PYTHON_BIN (defaults to the API's python), BP_FETCH_TIMEOUT_SECONDS=120
# Gemini 3+ thinking depth for the screening engine: minimal|low|medium|high
SCREENING_THINKING_LEVEL=minimal
